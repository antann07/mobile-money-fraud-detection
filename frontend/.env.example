# ============================================================
# React Frontend (Vite) — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# All variables must start with VITE_ to be exposed to the browser.
# ============================================================

# Backend API base URL (no trailing slash)
# Development:   http://127.0.0.1:5001
# Docker:        (empty — Nginx proxies /api on same origin)
# Production:    https://your-api.onrender.com  (your Render backend URL)
VITE_API_BASE=http://127.0.0.1:5001
