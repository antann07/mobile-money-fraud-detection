# ============================================================
# React Frontend (Vite) — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# All variables must start with VITE_ to be exposed to the browser.
# ============================================================

# Backend API base URL — must include the /api path segment
# Development:   http://127.0.0.1:5001/api
# Docker:        http://localhost:5001/api  (or leave unset to use default)
# Production:    https://mobile-money-fraud-detection-22ta.onrender.com/api
VITE_API_BASE_URL=http://127.0.0.1:5001/api
