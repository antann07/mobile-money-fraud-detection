# ============================================================
# Docker Compose — Environment Variables
# ============================================================
# Copy to .env at the project root (next to docker-compose.yml).
# Lines starting with # are comments. Uncomment to override.
# ============================================================

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=momo
POSTGRES_PASSWORD=changeme-use-a-real-password
POSTGRES_DB=fraud_detection
# Expose PG on this host port (default 5432)
# DB_PORT=5432

# ── Flask Backend ───────────────────────────────────────────
# REQUIRED — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-generate-a-real-secret
# JWT_SECRET defaults to SECRET_KEY if not set
# JWT_SECRET=

# Token lifetime in hours
TOKEN_EXPIRY_HOURS=24

# ── CORS ────────────────────────────────────────────────────
# Must match the URL users visit in their browser
CORS_ORIGINS=http://localhost:3000

# ── Email / SMTP ────────────────────────────────────────────
# Leave blank to disable email sending (tokens logged to console).
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=1
# MAIL_USERNAME=yourapp@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_DEFAULT_FROM=yourapp@gmail.com

# Frontend URL for links in emails (must match where users access the app)
FRONTEND_URL=http://localhost:3000

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Host Ports ──────────────────────────────────────────────
# Port the frontend is exposed on (users visit this)
APP_PORT=3000
