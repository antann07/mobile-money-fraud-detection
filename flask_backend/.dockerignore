# ── Files Docker should NOT copy into the image ─────────────
# Keeps the build context small and avoids leaking secrets.

# Environment / secrets
.env
.env.*
!.env.example

# Python artifacts
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Database files (SQLite)
*.db

# Uploaded files (use a Docker volume instead)
uploads/screenshots/*

# Logs
logs/

# Tests and debug scripts
test_*.py
debug_*.py
e2e_*.py
smoke_*.py

# IDE / OS
.vscode/
.idea/
*.swp
Thumbs.db
.DS_Store

# Docker (avoid recursive copy)
Dockerfile
docker-compose*.yml
.dockerignore

# Documentation
*.md
postman/
