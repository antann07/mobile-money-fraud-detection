# ============================================================
# Flask Backend — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# python-dotenv loads it automatically on startup.
# ============================================================

# ── Flask Mode ──────────────────────────────────────────────
# "development" or "production"
FLASK_ENV=development
FLASK_DEBUG=1

# ── Secret Keys (REQUIRED in production) ────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production
# JWT_SECRET defaults to SECRET_KEY if not set separately
# JWT_SECRET=

# ── Database ────────────────────────────────────────────────
# SQLite (default): leave blank to use fraud_detection.db in flask_backend/
# PostgreSQL: postgresql://user:password@host:5432/dbname
# DATABASE_URL=
# DATABASE_URL=postgresql://momo:secret@localhost:5432/fraud_detection

# ── File Uploads ────────────────────────────────────────────
# Directory for screenshot uploads (default: flask_backend/uploads/screenshots)
# UPLOAD_DIR=

# ── Max Upload Size ─────────────────────────────────────────
# In bytes. Default: 5242880 (5 MB)
# MAX_CONTENT_LENGTH=5242880

# ── ML Model Directory ──────────────────────────────────────
# Where the trained .pkl files live (default: ml/model/ in project root)
# MODEL_DIR=

# ── Tesseract OCR ───────────────────────────────────────────
# Full path to the Tesseract binary if it is not on PATH
# Windows example: C:\Program Files\Tesseract-OCR\tesseract.exe
# Linux/Docker: usually on PATH, leave blank
# TESSERACT_CMD=

# ── JWT Token Lifetime ──────────────────────────────────────
TOKEN_EXPIRY_HOURS=24

# ── CORS Allowed Origins ────────────────────────────────────
# Comma-separated list, or "*" for allow-all (dev only)
# Production example: CORS_ORIGINS=https://yourapp.com
# Legacy alias ALLOWED_ORIGINS is also supported
CORS_ORIGINS=*

# ── Email / SMTP ────────────────────────────────────────────
# Configure to enable registration welcome emails and password reset emails.
# Leave blank in development — emails are logged to console instead.
# Gmail example: use an App Password, not your main password.
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=1
# MAIL_USERNAME=yourapp@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_DEFAULT_FROM=yourapp@gmail.com

# ── Email Verification ──────────────────────────────────────
# Set to 1 to require email verification after registration.
# When disabled (default), a welcome email is sent instead.
# EMAIL_VERIFICATION_ENABLED=0
# EMAIL_VERIFICATION_EXPIRY_HOURS=24

# ── Frontend URL (for email links) ─────────────────────────
# Used to build password-reset, verification, and login links in emails.
FRONTEND_URL=http://localhost:3000

# ── Logging ─────────────────────────────────────────────────
# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
